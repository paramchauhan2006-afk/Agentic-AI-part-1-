# ==============================================================================
# Environment Configuration Template for Multi-Agent Framework
# Copy this file to '.env' and fill in your custom values.
# ==============================================================================

# Gemini API Keys (For google-genai, google-adk, and LangChain Google integrations)
GEMINI_API_KEY=your_gemini_api_key_here

# Vector Store Path (For the RAG Agent local database storage)
VECTOR_STORE_PATH=./data/vector_store

# Email SMTP Configurations (For the Email Agent dispatch notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_SENDER=your_email@gmail.com
SMTP_RECEIVER=recipient_email@example.com
